# AI estimates
# Required for live Claude estimates. If empty, the app falls back to heuristic pricing.
ANTHROPIC_API_KEY=

# Supabase client
# Public keys used by the browser and Supabase SSR helpers.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy Supabase projects may call this the anon key. The app accepts either.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server
# Required for server-side inserts/admin reads, bookings, leads, analytics, and admin data.
SUPABASE_SECRET_KEY=
# Legacy fallback name. The app accepts either.
# SUPABASE_SERVICE_ROLE_KEY=

# Public contact links
NEXT_PUBLIC_CONTACT_EMAIL=hello@maggie.agency
NEXT_PUBLIC_WHATSAPP=910000000000
NEXT_PUBLIC_CAL_LINK=https://cal.com/your-handle/intro

# Transactional emails
# Required for booking confirmation emails. Create this in Resend.
RESEND_API_KEY=
BOOKING_EMAIL_FROM=Maggie's Agency <admin@maggie.agency>
BOOKING_NOTIFY_EMAIL=admin@maggie.agency

# Simple booking-admin access
# Used by /api/bookings/admin. Change before deploying publicly.
ADMIN_PASSWORD=@ThyMaggie

# Team invite email copy metadata
# Used inside Supabase's Invite user email template via {{ .Data.inviter_email }}.
ADMIN_INVITER_EMAIL=admin@maggie.agency
ADMIN_INVITER_NAME=Maggie
