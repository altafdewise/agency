# ── Server-only (never exposed to the client) ──────────────────────────────
# Used by app/api/estimate/route.ts. Without it, the estimate route falls back
# to a grounded heuristic from PRICING_TABLE, so the path still works in dev.
ANTHROPIC_API_KEY=sk-ant-...

# ── Public CTA links (Step 8) ──────────────────────────────────────────────
# WhatsApp number = digits only, with country code, no "+" or spaces.
NEXT_PUBLIC_CAL_LINK=https://cal.com/your-handle/intro
NEXT_PUBLIC_WHATSAPP=910000000000
NEXT_PUBLIC_CONTACT_EMAIL=hello@maggie.agency
